{
  "name": "{{applicationName.paramCase()}}",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "preinstall": "pnpm dlx only-allow pnpm",
    "dev": "ng serve",
    "start": "ng serve --configuration production",
    "build": "ng build && find dist/browser -mindepth 1 -maxdepth 1 -exec mv {} dist/browser/.. \\; && rmdir dist/browser",
    "lint": "eslint 'src/**/*.{js,jsx,ts,tsx,html}'",
    "lint:fix": "eslint 'src/**/*.{js,jsx,ts,tsx,html}' --fix",
    "test": "ng test",
    "test:headless": "ng test --watch=false"
  },
  "dependencies": {
    "@angular/animations": "^21.2.5",
    "@angular/common": "^21.2.5",
    "@angular/compiler": "^21.2.5",
    "@angular/core": "^21.2.5",
    "@angular/forms": "^21.2.5",
    "@angular/platform-browser": "^21.2.5",
    "@angular/platform-browser-dynamic": "^21.2.5",
    "@angular/router": "^21.2.5",
    "@jsverse/transloco": "^8.2.1",
    "@ngrx/component-store": "^21.1.0",
    "@ngrx/effects": "^21.1.0",
    "@ngrx/store": "^21.1.0",
    "@ngrx/store-devtools": "^21.1.0",
    "@sentry/angular": "^10.45.0",
    "lodash-es": "^4.17.23",
    "ngx-fastboot": "^2.1.0",
    "ngxtension": "^7.2.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.3",
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.5",
    "@devmy/eslint-plugin": "^1.3.0",
    "@ngx-env/builder": "^21.0.1",
    "@types/lodash-es": "^4.17.12",
    "@typescript-eslint/eslint-plugin": "8.57.2",
    "@tailwindcss/postcss": "^4.1.12",
    "esbuild": "0.27.4",
    "eslint": "^9.39.4",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "executionEnv": {
      "nodeVersion": "22.12.0"
    }
  },
  "nx": {
    "targets": {
      "build": {
        "inputs": [
          "default",
          "environment"
        ]
      }
    }
  }
}
